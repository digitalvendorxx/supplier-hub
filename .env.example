PORT=3100

# Active data source: easyship | mock | navlungo | shipentegra | email
DATA_SOURCE=mock

# Easyship (fill in after signup)
EASYSHIP_API_TOKEN=
EASYSHIP_API_BASE=https://public-api.easyship.com

# Poll interval for fetching new orders (ms)
POLL_INTERVAL_MS=120000

# Session cookie signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# Optional: auto-assign ingested stores to this store_owner user_id.
# If unset, new stores from Easyship poller stay unowned until admin assigns an owner.
DEFAULT_STORE_OWNER_ID=
